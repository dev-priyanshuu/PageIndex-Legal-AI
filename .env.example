# ─────────────────────────────────────────────────────────────────────────────
# Legal Agentic PageIndex RAG — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────


# ── Application ───────────────────────────────────────────────────────────────

# Environment: dev | staging | prod
APP_ENV=dev

# FastAPI backend URL (used by the Streamlit frontend)
# Local dev: http://127.0.0.1:8000
# Deployed:  https://your-backend.railway.app
BACKEND_URL=http://127.0.0.1:8000


# ── Storage ───────────────────────────────────────────────────────────────────

# Backend: memory (no persistence) | sqlite (local file) | postgres
STORAGE_BACKEND=sqlite

# Path to SQLite database file (used when STORAGE_BACKEND=sqlite)
SQLITE_PATH=data/legal_ai.db

# PostgreSQL connection string (used when STORAGE_BACKEND=postgres)
# POSTGRES_DSN=postgresql://user:password@localhost:5432/legal_ai

# Redis cache URL (optional — for future caching layer)
# REDIS_URL=redis://localhost:6379/0

# AWS S3 bucket for document storage (optional — for future cloud storage)
# S3_BUCKET=your-legal-docs-bucket


# ── LLM Provider ─────────────────────────────────────────────────────────────

# Only Google Gemini is supported. Set to "gemini".
LLM_PROVIDER=gemini

# Your Google Gemini API key
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Primary Gemini model (first choice for all LLM calls)
# Recommended: models/gemini-2.5-flash  (fast, 1M token context, best for legal docs)
GEMINI_MODEL=models/gemini-2.5-flash

# Fallback model chain — tried in order if the primary model fails or is unavailable
# Format: comma-separated list, no spaces
GEMINI_MODELS=models/gemini-2.5-flash,gemini-2.5-flash,models/gemini-2.5-pro,gemini-2.5-pro,models/gemini-2.0-flash-001,gemini-2.0-flash-001,models/gemini-flash-latest,gemini-flash-latest


# ── PageIndex Tree Generation ─────────────────────────────────────────────────

# Gemini model used by the VectifyAI/PageIndex engine to build the document tree
# Should match GEMINI_MODEL or be a stable model name
PAGEINDEX_MODEL=models/gemini-2.5-flash

# Tree generation mode:
#   auto      → use real PageIndex (LLM-powered) if GEMINI_API_KEY is set, else fall back to local
#   pageindex → always use VectifyAI/PageIndex (requires GEMINI_API_KEY)
#   local     → always use local regex/font-based tree builder (no API key needed)
TREE_GENERATION_MODE=auto


# ── LangSmith Observability ───────────────────────────────────────────────────

# Master on/off switch — set to "true" to enable tracing
LANGCHAIN_TRACING_V2=true

# Your LangSmith API key
# Get one at: https://smith.langchain.com → Settings → API Keys
LANGSMITH_API_KEY=your_langsmith_api_key_here

# Project name shown in the LangSmith UI
LANGSMITH_PROJECT=pageindex-legal-ai

# LangSmith endpoint (default is fine for most users)
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
