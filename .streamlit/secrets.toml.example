# Streamlit Cloud secrets — copy to .streamlit/secrets.toml for local use
# On Streamlit Cloud, add these under App Settings → Secrets

# URL of your deployed FastAPI backend (e.g. on Railway, Render, or Fly.io)
BACKEND_URL = "https://your-backend.railway.app"

# Gemini API key (used by the backend — set this in your backend's env, not here)
# GEMINI_API_KEY = "your_gemini_api_key_here"
